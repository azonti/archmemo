{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
  ],
  minimumReleaseAge: "7 days",
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: [ "/^archmemo_.+\\.sh$/" ],
      matchStrings: [ 'go install (?<depName>[^@]+)@(?<currentValue>.+)' ],
      datasourceTemplate: "go",
    },
  ],
  packageRules: [
    {
      matchFileNames: [ "/^archmemo_.+\\.sh$/" ],
      automerge: true,
    },
  ],
}
